---
import HomeLayout from '$layouts/HomeLayout.astro';
import Header from '$components/PageHeader.astro';
import Heading from '$components/Heading.astro';
import '$assets/article.css';

import { Content } from './_about.md';
---

<HomeLayout
	title="About — Sid Vishnoi — Independent software engineer, full-stack developer"
	meta={{
		description: `I'm Sid, a passionate software engineer and full-stack web developer with a knack for front-end development.`,
	}}
>
	<Header />
	<article>
		<Heading tag="h2">About</Heading>
		<Content />
	</article>
</HomeLayout>

<style is:global>
	br {
		display: block;
		margin-top: 0.3em;
	}
</style>
