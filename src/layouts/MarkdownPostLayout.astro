---
import HomeLayout from '$layouts/HomeLayout.astro';
import Header from '$components/Header.astro';
import { withParams } from '$lib/utils.ts';
import '$assets/style.css';
import type { CollectionEntry } from 'astro:content';

type Props = {
	frontmatter: CollectionEntry<'blog'>['data'];
};

const { frontmatter: fm } = Astro.props;
const { title, description } = fm;
const shareImage = fm.image?.url ? new URL(fm.image?.url) : undefined;
const canonical = new URL(fm.canonical || Astro.url.pathname, Astro.site);

const formatDate = (date: Date) =>
	date.toLocaleDateString('en', {
		dateStyle: 'long',
	});
---

<HomeLayout
	title=`${title} | Sid Vishnoi's blog`
	meta={{ canonical, description, shareImage }}
>
	<Header isSmall />

	<article id="main">
		<header>
			<h1 style="font-weight: bold">
				<a href={canonical.href}>{title}</a>
			</h1>

			<div class="meta">
				<p>
					Published <time datetime={fm.date.toISOString()}
						>{formatDate(fm.date)}</time
					>
					{
						fm.modified && (
							<Fragment>
								and last updated{' '}
								<time datetime={fm.modified.toISOString()}>
									{formatDate(fm.modified)}
								</time>
							</Fragment>
						)
					}
					{
						fm.canonical && (
							<Fragment>
								∙ Originally published on{' '}
								<a
									href={
										withParams(fm.canonical, { ref: 'sidvishnoi.com' }).href
									}
									target="_blank"
									rel="nofollow"
								>
									{new URL(fm.canonical).hostname}
								</a>
							</Fragment>
						)
					}
				</p>
			</div>
		</header>

		<div>
			<slot />
		</div>
	</article>
</HomeLayout>

<style is:global>
	main * {
		margin: revert;
		padding: revert;
	}

	article {
		max-width: min(calc(100% - 2 * var(--border-thickness)), 80ch);
		margin: 0 auto;
		margin-top: 3rem;
		padding: 0 1em 1em;
		font-size: clamp(1em, 18px + 0.24vw, 2.125em);
	}

	article > *  {
		max-width: 65ch;
		margin: 0 auto;
	}

	article h1 {
		line-height: 1.1;
		margin-bottom: 0.25em;
	}

	article h1 a {
		color: inherit;
		text-decoration: none;
	}

	article header .meta {
		margin-bottom: 2rem;
		border-bottom: 1px solid #ddd;
		font-size: smaller;
		color: var(--color-alt, #777);
	}
	article header .meta p {
		font-size: smaller;
	}

	article ol {
		margin-left: -0.5em;
	}

	article ul {
		margin-left: -1.5em;
	}

	article :is(p, li) code {
		font-family: var(--font-mono);
		font-size: 0.85em;
	}

	hr {
		margin: 2em auto;
		border: 2px solid var(--color-c, aquagreen);
		border-radius: 10px;
		max-width: 60%;
	}
</style>
